# 复制为 .env 并填入真实值：cp .env.example .env
# .env 已被 .gitignore 忽略，不会进版本库。

# LLM provider（OpenAI 兼容 Responses API）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://node-cf.sssaicodeapi.com/api/v1
OPENAI_MODEL=gpt-5.4
OPENAI_MAX_OUTPUT_TOKENS=8000

# 可选
# IBKR_SCRIPTS_DIR=~/Desktop/ibkr-options-assistant/scripts
# TRADEMIND_DB=~/Desktop/TradeMind_Agent/agent/db/trademind.db
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
